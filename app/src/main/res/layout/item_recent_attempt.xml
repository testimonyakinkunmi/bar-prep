<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_option_default"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_recent_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Week 3 · Courts with Civil Jurisdiction"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:fontFamily="@font/inter_semibold" android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/tv_recent_date"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Today at 2:30 PM"
            android:textColor="@color/text_secondary" android:textSize="11sp"
            android:layout_marginTop="3dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end">
        <TextView android:id="@+id/tv_recent_score"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="80%"
            android:textColor="@color/correct_green" android:textSize="18sp"
            android:fontFamily="@font/inter_bold"/>
        <TextView android:id="@+id/tv_recent_fraction"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="28/35"
            android:textColor="@color/text_secondary" android:textSize="11sp"/>
    </LinearLayout>
</LinearLayout>
