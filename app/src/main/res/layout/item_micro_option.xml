<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_option_default"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tv_option_letter"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="A"
        android:textColor="@color/accent_gold"
        android:textSize="12sp"
        
        android:background="@drawable/bg_streak_badge"
        android:layout_marginEnd="10dp"/>

    <TextView
        android:id="@+id/tv_option_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Option text"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"/>
</LinearLayout>
