<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_option_default"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_review_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textColor="@color/correct_green"
            android:textSize="16sp"
            
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_review_q_num"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Q1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_review_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Question text"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_review_your_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your answer: ..."
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tv_review_correct_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Correct: ..."
        android:textColor="@color/correct_green"
        android:textSize="12sp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tv_review_explanation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="6dp"
        android:visibility="gone"/>
</LinearLayout>
