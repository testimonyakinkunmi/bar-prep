<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_900"
    android:orientation="vertical">

    <!-- Score hero -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="60dp"
        android:paddingBottom="32dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/tvResultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quiz Complete!"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvWeekResultLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Week 3 · Courts with Civil Jurisdiction"
            android:textColor="@color/slate_400"
            android:textSize="13sp"
            android:layout_marginBottom="28dp"/>

        <!-- Score circle -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/bg_score_circle"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvScorePercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="85%"
                    android:textColor="@color/gold_500"
                    android:textSize="40sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvScoreFraction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="17 / 20"
                    android:textColor="@color/slate_400"
                    android:textSize="14sp"/>
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/tvScoreMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Excellent work! 🎉"
            android:textColor="@color/gold_400"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- Corrections list -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"
        android:text="Detailed Corrections"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCorrections"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"/>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Retry"
            app:backgroundTint="@color/navy_700"
            app:cornerRadius="14dp"
            android:textColor="@color/slate_300"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Home"
            app:backgroundTint="@color/gold_500"
            app:cornerRadius="14dp"
            android:textColor="@color/navy_900"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
