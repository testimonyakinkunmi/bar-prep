<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:background="@color/color_surface"
    android:layout_marginBottom="2dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvBdWeek"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="W3"
        android:textColor="@color/gold_500"
        android:textSize="13sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvBdTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Courts"
        android:textColor="@color/slate_700"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.2"/>

    <TextView
        android:id="@+id/tvBdAttempted"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="0/35"
        android:textColor="@color/slate_400"
        android:textSize="12sp"/>

    <TextView
        android:id="@+id/tvBdAccuracy"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="–"
        android:textColor="@color/emerald_500"
        android:textSize="13sp"
        android:textStyle="bold"/>

</LinearLayout>
