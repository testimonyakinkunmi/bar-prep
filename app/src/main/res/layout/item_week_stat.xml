<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_option_default"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">

        <TextView android:id="@+id/tv_wstat_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Week 3 · Courts with Civil Jurisdiction"
            android:textColor="@color/text_primary"
            android:textSize="13sp" 
            android:maxLines="1" android:ellipsize="end"/>

        <TextView android:id="@+id/tv_wstat_best"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Best: 92%"
            android:textColor="@color/accent_gold"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">

        <FrameLayout android:layout_width="0dp" android:layout_height="6dp"
            android:layout_weight="1" android:layout_marginEnd="10dp"
            android:background="@drawable/bg_progress_bar_track">
            <View android:id="@+id/view_wstat_bar"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:background="@drawable/bg_progress_bar_fill"/>
        </FrameLayout>

        <TextView android:id="@+id/tv_wstat_avg"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Avg 78%"
            android:textColor="@color/text_secondary" android:textSize="11sp"/>

        <TextView android:id="@+id/tv_wstat_attempts"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text=" · 3 attempts"
            android:textColor="@color/text_tertiary" android:textSize="11sp"/>
    </LinearLayout>
</LinearLayout>
