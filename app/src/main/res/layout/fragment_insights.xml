<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_midnight">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Insights" android:textColor="@color/text_primary"
            android:textSize="22sp" android:fontFamily="@font/inter_bold" android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Data-driven study analytics" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="20dp"/>

        <!-- Toggle chips -->
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:scrollbars="none" android:layout_marginBottom="20dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView android:id="@+id/chip_score"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Score Trend" android:gravity="center"
                    android:paddingHorizontal="16dp" android:textSize="13sp"
                    android:fontFamily="@font/inter_semibold"
                    android:textColor="@color/text_on_accent"
                    android:background="@drawable/bg_streak_badge"
                    android:layout_marginEnd="8dp"/>

                <TextView android:id="@+id/chip_heatmap"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Topic Heatmap" android:gravity="center"
                    android:paddingHorizontal="16dp" android:textSize="13sp"
                    android:fontFamily="@font/inter_semibold"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_week_chip"
                    android:layout_marginEnd="8dp"/>

                <TextView android:id="@+id/chip_accuracy"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Q Accuracy" android:gravity="center"
                    android:paddingHorizontal="16dp" android:textSize="13sp"
                    android:fontFamily="@font/inter_semibold"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_week_chip"
                    android:layout_marginEnd="8dp"/>

                <TextView android:id="@+id/chip_weakest"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Weak Areas" android:gravity="center"
                    android:paddingHorizontal="16dp" android:textSize="13sp"
                    android:fontFamily="@font/inter_semibold"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_week_chip"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Chart container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_chart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardBackgroundColor="#111D2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:id="@+id/tv_chart_title"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Score Trend" android:textColor="@color/text_primary"
                    android:textSize="15sp" android:fontFamily="@font/inter_semibold"
                    android:layout_marginBottom="16dp"/>

                <!-- Custom chart view -->
                <com.barprepng.app.ui.insights.LineChartView
                    android:id="@+id/chart_view"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"/>

                <TextView android:id="@+id/tv_chart_empty"
                    android:layout_width="match_parent" android:layout_height="100dp"
                    android:text="Complete quizzes to see your trend"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:gravity="center" android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Heatmap card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_heatmap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardBackgroundColor="#111D2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Topic Accuracy Heatmap"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="@font/inter_semibold" android:layout_marginBottom="6dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Darker = stronger. Lighter = needs work."
                    android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_marginBottom="16dp"/>

                <com.barprepng.app.ui.insights.HeatmapView
                    android:id="@+id/heatmap_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Question Accuracy list -->
        <LinearLayout android:id="@+id/container_accuracy"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hardest Questions" android:textColor="@color/text_primary"
                android:textSize="16sp" android:fontFamily="@font/inter_semibold"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_accuracy"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>

        <!-- Weak areas -->
        <LinearLayout android:id="@+id/container_weak"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Weak Areas — Focus Here"
                android:textColor="@color/text_primary" android:textSize="16sp"
                android:fontFamily="@font/inter_semibold" android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_weak"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_drill_weak"
                style="@style/Widget.BarPrep.Button.Primary"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="🎯 Drill Weak Areas"/>
        </LinearLayout>

        <TextView android:id="@+id/tv_insights_empty"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Complete at least one quiz to unlock insights."
            android:textColor="@color/text_secondary" android:textSize="14sp"
            android:gravity="center" android:paddingVertical="32dp"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
