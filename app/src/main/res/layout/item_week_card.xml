<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#111D2E"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Week number badge -->
        <TextView
            android:id="@+id/tv_week_badge"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/text_on_accent"
            android:textSize="14sp"
            android:fontFamily="@font/inter_bold"
            android:background="@drawable/bg_streak_badge"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_week_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Courts with Civil Jurisdiction"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_semibold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tv_question_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="35 questions"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginEnd="10dp"/>

                <!-- Progress bar -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_bar_track">

                    <View
                        android:id="@+id/view_progress"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_progress_bar_fill"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_best_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/accent_gold"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_semibold"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="@color/text_tertiary"
            android:textSize="22sp"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
