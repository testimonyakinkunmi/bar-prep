<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BarPrep" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/accent_gold</item>
        <item name="colorPrimaryVariant">@color/accent_gold_dark</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorSecondary">@color/accent_gold_light</item>
        <item name="colorOnSecondary">@color/text_on_accent</item>
        <item name="colorSurface">@color/brand_navy_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/brand_midnight</item>
        <item name="android:windowBackground">@color/brand_midnight</item>
        <item name="android:statusBarColor">@color/brand_midnight</item>
        <item name="android:navigationBarColor">@color/brand_midnight</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.BarPrep.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_midnight</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.BarPrep</item>
    </style>

    <style name="TextAppearance.BarPrep.H1" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.BarPrep.H2" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.BarPrep.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/brand_navy_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.BarPrep.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_gold</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.BarPrep.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_gold</item>
        <item name="android:textColor">@color/accent_gold</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
