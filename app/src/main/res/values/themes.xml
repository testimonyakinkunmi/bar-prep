<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BarPrepNG" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/navy_800</item>
        <item name="colorPrimaryVariant">@color/navy_900</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorSecondary">@color/gold_500</item>
        <item name="colorSecondaryVariant">@color/gold_400</item>
        <item name="colorOnSecondary">@color/navy_900</item>
        <item name="android:colorBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_text_primary</item>
        <item name="android:statusBarColor">@color/navy_900</item>
        <item name="android:navigationBarColor">@color/navy_900</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.BarPrepNG.Splash" parent="Theme.BarPrepNG">
        <item name="android:windowBackground">@color/navy_900</item>
        <item name="android:statusBarColor">@color/navy_900</item>
    </style>

    <style name="OptionButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textColor">@color/slate_900</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="strokeColor">@color/slate_300</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="rippleColor">@color/gold_300</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="Widget.BarPrep.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/brand_midnight</item>
        <item name="strokeColor">@color/brand_midnight</item>
    </style>

    <style name="Widget.BarPrep.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/color_on_primary</item>
        <item name="backgroundTint">@color/navy_800</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="OptionButton.Correct">
        <item name="android:textColor">@color/emerald_600</item>
        <item name="strokeColor">@color/emerald_500</item>
        <item name="backgroundTint">@color/emerald_100</item>
    </style>

    <style name="OptionButton.Wrong">
        <item name="android:textColor">@color/rose_600</item>
        <item name="strokeColor">@color/rose_500</item>
        <item name="backgroundTint">@color/rose_100</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/color_surface</item>
    </style>

    <style name="WeekCard" parent="CardStyle">
        <item name="cardElevation">2dp</item>
    </style>
</resources>
